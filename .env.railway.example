# ════════════════════════════════════════════════════════════════
#  MAGICLAMP — Railway / single-service deploy environment
#  Copy to .env and fill the values for the LLM provider you pick.
#  Everything else has sane defaults — you do NOT need Supabase,
#  Redis, n8n or Ollama for this deployment mode.
# ════════════════════════════════════════════════════════════════

# ── Required: app secrets ───────────────────────────────────────
# Generate each with:  openssl rand -hex 32
JWT_SECRET=replace_with_openssl_rand_hex_32
BRAIN_SECRET=replace_with_openssl_rand_hex_32

# ── Required: LLM provider ──────────────────────────────────────
# Choose ONE of: openai | anthropic | groq | openrouter | gemini
# (ollama is supported only on multi-service VPS deploys)
LLM_PROVIDER=openai

# Then provide the matching API key. Only the key for the provider
# you pick is required — all others can be left unset.
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant

# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# ── Defaults that you usually do NOT need to change ─────────────
DB_BACKEND=sqlite                # Use the bundled SQLite store (no external DB)
BRAIN_DATA_DIR=/data/brain       # SQLite file + exports — back this with a Railway Volume
RAG_ENABLED=false                # Local Chroma RAG; flip to true to enable (uses extra RAM)
BRAIN_AUTO_MODE=false            # Background scheduler — keep off for hosted LLM mode
ENV=production
