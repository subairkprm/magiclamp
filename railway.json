{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "brain/Dockerfile",
    "buildArgs": {
      "INCLUDE_RAG_MODEL": "false"
    }
  },
  "deploy": {
    "startCommand": "uvicorn brain.main:app --host 0.0.0.0 --port ${PORT:-9000} --workers 1",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  },
  "volumes": [
    {
      "name": "magiclamp-data",
      "mountPath": "/data/brain"
    }
  ]
}
