# ═══════════════════════════════════════════════
#  MAGICLAMP — Environment Configuration
#  Copy to .env and fill all required values
# ═══════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────
SUPABASE_URL=https://qdjzzvlhawzttgharjfw.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

JWT_SECRET=generate_with_openssl_rand_hex_32_here
BRAIN_SECRET=generate_with_openssl_rand_hex_32_here

# ── TELEGRAM ─────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id

# ── N8N ──────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change_this_strong_password
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32_here
N8N_API_KEY=

# ── AI MODEL ─────────────────────────────────
OLLAMA_MODEL=qwen2.5:7b

# ── BRAIN ────────────────────────────────────
BRAIN_AUTO_MODE=true

# ── RAG / Vector memory ──────────────────────
# Master feature flag. Leave false until backfill has completed.
RAG_ENABLED=false
# Embedding provider: "local" (sentence-transformers) or "ollama"
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Vector store: "chroma" (persistent) or "memory" (tests)
VECTOR_STORE=chroma
# VECTOR_STORE_PATH=/data/brain/chroma
VECTOR_COLLECTION=brain_facts
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.0

# ── SERVER ───────────────────────────────────
# Your VPS IP or domain
SERVER_HOST=YOUR_VPS_IP_OR_DOMAIN
